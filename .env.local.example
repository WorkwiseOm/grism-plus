# ==========================================
# Grism Plus - Environment Variables
# ==========================================

# Base URL for the application
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------- Supabase Integration ----------
# Cloud project values. Dashboard: Project Settings → API → "Legacy API keys"
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key-here"

# ⚠️ Service role key bypasses RLS - keep secret and never expose to client
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key-here"

# Database password (used by supabase CLI `db push` / `gen types --db-url`)
SUPABASE_DB_PASSWORD="your-db-password-here"

# HMAC key for pseudonymising employee identifiers in AI prompts.
# Generate with: openssl rand -hex 32
HMAC_SESSION_KEY="change-me-dev-only"

# ---------- Provider Integrations ---------
# Resend API key for transactional emails
RESEND_API_KEY="re_..."

# Anthropic API key and default model for AI nodes
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_MODEL="claude-sonnet-4-5-20250929"

# ---------- Demo mode ----------
# Enables a demo-persona switcher on /auth/sign-in and bypasses MFA
# enforcement in middleware. The gate has TWO mutually exclusive paths:
#
# Path 1 — local development. All three must hold:
#   - NODE_ENV != "production"
#   - DEMO_AUTH_RELAXED == "true"
#   - Host header is loopback (localhost / 127.0.0.1 / ::1)
# This is the safe default — Vercel sets NODE_ENV=production on every
# deploy, so leaking DEMO_AUTH_RELAXED into Vercel alone cannot open
# the gate; the host check still rejects.
#
# Path 2 — deployed behind operator-verified Deployment Protection.
# All three must hold:
#   - DEMO_AUTH_RELAXED == "true"
#   - DEMO_AUTH_DEPLOYED_BEHIND_PROTECTION == "true"
#   - Host header is NOT a loopback address
# Setting BOTH flags is your acknowledgment that you have verified
# Vercel SSO Deployment Protection (or an equivalent network gate) is
# enabled for ALL deployment URLs of this project, including the bare
# project alias. For Vercel projects this means
# `ssoProtection.deploymentType === "all"` — the default
# "all_except_custom_domains" leaves the bare alias publicly reachable
# and is NOT enough for this path. The two-key acknowledgment exists
# so a single DEMO_AUTH_RELAXED leak cannot expose one-click admin
# sign-in in production.
# DEMO_AUTH_RELAXED="true"
# DEMO_AUTH_DEPLOYED_BEHIND_PROTECTION="true"

# Shared passcode for the deployed demo gate. When the path-2 demo gate
# is enabled (both flags above set to "true"), middleware redirects every
# request without a valid signed cookie to /demo-gate, which prompts for
# this passcode. The cookie is HMAC-signed with HMAC_SESSION_KEY so it
# cannot be forged. Generate with: openssl rand -base64 24
# DEMO_GATE_PASSCODE=""

# Per-persona passwords for the local demo switcher. Source: stdout of
# `npx tsx scripts/seed_phase1_demo.ts` after a seed run (the credential
# block written to your local tempfile). Personas with no password set
# here are simply hidden from the switcher; missing entries do not error.
# DEMO_PERSONA_YUSUF_PASSWORD=""
# DEMO_PERSONA_AISHA_PASSWORD=""
# DEMO_PERSONA_KHALID_PASSWORD=""
# DEMO_PERSONA_FATIMA_PASSWORD=""
# DEMO_PERSONA_OMAR_PASSWORD=""
# DEMO_PERSONA_SAIF_PASSWORD=""
